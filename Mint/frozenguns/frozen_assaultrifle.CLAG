=AUTOMATIC: True
#CLIP_SIZE: 30
#ROUNDS_PER_RELOAD: 30
%SECONDS_TO_RELOAD: 3
%BULLETS_PER_SECOND: 10
"RELOAD_SFX: AssaultReload
