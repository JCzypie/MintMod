Firearm
$AUTHOR: JCzypie

$ID mint_frozenassaultrifle
$NAME: Frozen Assault Rifle
$DESCRIPTION1: High power full auto
$DESCRIPTION2: Uses Diamond Bullets

$"MODEL: Assault Rifle
"ANIMATION: Assault Rifle
*MODEL_COLOR1: 32, 64, 255
*MODEL_COLOR2: 255, 255, 255

%ZOOM_AMOUNT: 2
=SCOPED: False
=HIDE_CROSSHAIR: False

$AMMO_NAME: Diamond Bullets
"PROJECTILE_TYPE: Normal
%BULLET_SPEED: 100
%BULLET_LIFETIME: 2
